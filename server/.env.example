# ── MongoDB ──────────────────────────────────────────
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/beetel

# ── App Secrets ──────────────────────────────────────
SECRET_KEY=change-me-to-a-random-string

# ── Admin Login ──────────────────────────────────────
ADMIN_USER=admin
ADMIN_PASS=changeme

# ── ESP32 API Key ────────────────────────────────────
ESP32_API_KEY=your-esp32-api-key

# ── Spotify (optional, for metadata lookup & playback) ──
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=
